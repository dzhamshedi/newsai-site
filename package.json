{
  "name": "newsai-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js && npm run format:check",
    "lint:html": "htmlhint \"**/*.html\"",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:js": "eslint .",
    "memory:status": "node scripts/memory-status.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "htmlhint": "^1.9.2",
    "prettier": "^3.8.3",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0"
  }
}
